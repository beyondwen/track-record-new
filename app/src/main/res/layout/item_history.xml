<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="?attr/materialCardViewElevatedStyle"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@android:color/transparent"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:strokeColor="#164A6267"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/history_card_background"
        android:descendantFocusability="blocksDescendants"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:id="@+id/tvGroupHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/history_group_header_background"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:text="@string/history_group_today"
            android:textColor="@color/md_theme_light_onPrimaryContainer"
            android:textSize="11sp"
            android:textStyle="bold"
            tools:visibility="visible" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/history_icon_background">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_history"
                    android:tint="@color/md_theme_light_primary" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvHistoryTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/md_theme_light_onPrimaryContainer"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    tools:text="行程 #01" />

                <TextView
                    android:id="@+id/tvHistoryTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/md_theme_light_onSurfaceVariant"
                    android:textSize="12sp"
                    tools:text="03月21日 20:30" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvHistoryAction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/history_status_background"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:text="@string/history_action_view"
                android:textColor="@color/md_theme_light_onSecondaryContainer"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvHistorySummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:lineSpacingExtra="2dp"
            android:text="@string/history_summary_default"
            android:textColor="@color/md_theme_light_onPrimaryContainer"
            android:textSize="13sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvHistoryPointCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/history_info_chip_background"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:textColor="@color/md_theme_light_onPrimaryContainer"
                android:textSize="11sp"
                android:textStyle="bold"
                tools:text="12 个定位点" />

            <TextView
                android:id="@+id/tvHistoryQuality"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:background="@drawable/history_status_background"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:textColor="@color/md_theme_light_onSecondaryContainer"
                android:textSize="11sp"
                android:textStyle="bold"
                tools:text="良好 82分" />

            <TextView
                android:id="@+id/tvHistoryHint"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="@string/history_preview_subtitle"
                android:textColor="@color/md_theme_light_onSurfaceVariant"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/history_preview_background"
            android:gravity="center_vertical"
            android:minHeight="88dp"
            android:orientation="horizontal"
            android:padding="12dp">

            <com.wenhao.record.ui.history.HistoryRoutePreviewView
                android:id="@+id/historyRoutePreview"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/history_preview_title"
                    android:textColor="@color/md_theme_light_onPrimaryContainer"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/history_preview_subtitle"
                    android:textColor="@color/md_theme_light_onSurfaceVariant"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/history_metric_tile_background"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/history_metric_distance"
                    android:textColor="@color/md_theme_light_onSurfaceVariant"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvHistoryDistance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/md_theme_light_onPrimaryContainer"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:text="3.25 公里" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@drawable/history_metric_tile_background"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/history_metric_duration"
                    android:textColor="@color/md_theme_light_onSurfaceVariant"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvHistoryDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/md_theme_light_onPrimaryContainer"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:text="25:30" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@drawable/history_metric_tile_background"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/history_metric_speed"
                    android:textColor="@color/md_theme_light_onSurfaceVariant"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvHistorySpeed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/md_theme_light_onPrimaryContainer"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:text="7.8 公里/小时" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvHistoryLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/history_info_chip_background"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:text="@string/history_card_latest_label"
            android:textColor="@color/md_theme_light_onPrimaryContainer"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
