<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dashboard_header_bg"
    tools:context=".ui.main.MainActivity">

    <FrameLayout
        android:id="@+id/headerContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/dashboard_header_background"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.baidu.mapapi.map.MapView
            android:id="@+id/homeMapView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="true" />

        <LinearLayout
            android:id="@+id/gpsStatusBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/dashboard_badge_background"
            android:elevation="2dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="8dp"
            android:paddingEnd="14dp"
            android:paddingBottom="8dp">

            <View
                android:id="@+id/gpsStatusDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/dashboard_ready_dot" />

            <TextView
                android:id="@+id/tvGpsStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/dashboard_gps_ready"
                android:textColor="@color/md_theme_light_onSurface"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutRecordDiagnosticsCompact"
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_marginTop="74dp"
            android:background="@drawable/history_metric_tile_background"
            android:elevation="2dp"
            android:orientation="vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="10dp">

            <TextView
                android:id="@+id/tvRecordDiagnosticsCompactTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="记录诊断"
                android:textColor="@color/md_theme_light_onPrimaryContainer"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvRecordDiagnosticsCompactBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:lineSpacingExtra="2dp"
                android:maxLines="5"
                android:text="正在整理诊断状态..."
                android:textColor="@color/md_theme_light_onSurfaceVariant"
                android:textSize="10sp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/btnLocate"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="14dp"
            android:layout_marginBottom="42dp"
            android:background="@drawable/dashboard_icon_button_background"
            android:clickable="true"
            android:contentDescription="@string/dashboard_locate"
            android:focusable="true"
            android:padding="10dp"
            android:src="@drawable/ic_locate_dashboard"
            android:tint="@color/md_theme_light_onSurface" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/dashboardPanel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="-28dp"
        android:background="@drawable/dashboard_panel_background"
        android:elevation="12dp"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="12dp"
        android:paddingEnd="24dp"
        android:paddingBottom="18dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerContainer">

        <View
            android:id="@+id/panelHandle"
            android:layout_width="42dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/dashboard_handle_background" />

        <LinearLayout
            android:id="@+id/recordContent"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="top|center_horizontal"
            android:orientation="vertical"
            android:paddingTop="20dp">

            <TextView
                android:id="@+id/tvDistanceValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:text="@string/dashboard_distance_value"
                android:textColor="@color/md_theme_light_onSurface"
                android:textSize="56sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.22"
                android:text="@string/dashboard_distance_unit"
                android:textColor="@color/md_theme_light_onSurfaceVariant"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:gravity="center"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.18"
                        android:text="@string/dashboard_time_label"
                        android:textColor="@color/md_theme_light_onSurfaceVariant"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvTimeValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/dashboard_time_value"
                        android:textColor="@color/md_theme_light_onSurface"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="42dp"
                    android:background="@color/md_theme_light_outlineVariant" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.18"
                        android:text="@string/dashboard_speed_label"
                        android:textColor="@color/md_theme_light_onSurfaceVariant"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvSpeedValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/dashboard_speed_value"
                        android:textColor="@color/md_theme_light_onSurface"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnStartRecord"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:background="@drawable/location_card_background"
                android:clickable="false"
                android:focusable="false"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="18dp"
                android:paddingVertical="16dp">

                <FrameLayout
                    android:layout_width="66dp"
                    android:layout_height="66dp">

                    <View
                        android:id="@+id/recordButtonHalo"
                        android:layout_width="66dp"
                        android:layout_height="66dp"
                        android:layout_gravity="center"
                        android:background="@drawable/dashboard_record_button_halo" />

                    <View
                        android:id="@+id/recordButtonFace"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:layout_gravity="center"
                        android:background="@drawable/dashboard_record_button_background" />

                    <ImageView
                        android:id="@+id/ivRecordAction"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_play_dashboard"
                        android:tint="@color/white" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvAutoTrackTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dashboard_auto_title_idle"
                        android:textColor="@color/md_theme_light_onSurface"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvAutoTrackMeta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/dashboard_auto_meta_idle"
                    android:textColor="@color/md_theme_light_onSurfaceVariant"
                    android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutRecordDiagnostics"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/history_metric_tile_background"
                android:orientation="vertical"
                android:paddingHorizontal="14dp"
                android:paddingVertical="12dp">

                <TextView
                    android:id="@+id/tvRecordDiagnosticsTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="记录诊断"
                    android:textColor="@color/md_theme_light_onPrimaryContainer"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvRecordDiagnosticsBody"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="3dp"
                    android:text="正在整理诊断状态..."
                    android:textColor="@color/md_theme_light_onSurfaceVariant"
                    android:textSize="11sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvRecordStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/dashboard_status_idle_background"
                android:paddingHorizontal="12dp"
                android:paddingVertical="7dp"
                android:text="@string/dashboard_status_ready"
                android:textColor="@color/md_theme_light_onPrimaryContainer"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvRecordHint"
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:lineSpacingExtra="2dp"
                android:text="@string/dashboard_hint_idle"
                android:textColor="@color/md_theme_light_onSurfaceVariant"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvPauseResumeAction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/history_status_background"
                android:clickable="true"
                android:focusable="true"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:text="@string/dashboard_pause_recording"
                android:textColor="@color/md_theme_light_onSecondaryContainer"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />
        </LinearLayout>

        <View
            android:id="@+id/panelDivider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="18dp"
            android:background="@color/md_theme_light_outlineVariant" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/tabRecord"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <ImageView
                    android:id="@+id/ivTabRecord"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_tab_record"
                    android:tint="@color/md_theme_light_primary" />

                <TextView
                    android:id="@+id/tvTabRecord"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/dashboard_record"
                    android:textColor="@color/md_theme_light_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tabHistory"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <ImageView
                    android:id="@+id/ivTabHistory"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_tab_history"
                    android:tint="@color/dashboard_nav_inactive" />

                <TextView
                    android:id="@+id/tvTabHistory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/dashboard_history"
                    android:textColor="@color/dashboard_nav_inactive"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/saveFeedbackCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="92dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="24dp"
        app:cardElevation="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:strokeColor="#1FD9D1C7"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <FrameLayout
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/history_icon_background">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_history"
                    android:tint="@color/md_theme_light_primary" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvSaveFeedbackTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/dashboard_save_feedback_title"
                    android:textColor="@color/md_theme_light_onPrimaryContainer"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSaveFeedbackSummary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/dashboard_save_feedback_placeholder"
                    android:textColor="@color/md_theme_light_onSurfaceVariant"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvSaveFeedbackAction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/history_info_chip_background"
                android:clickable="true"
                android:focusable="true"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:text="@string/dashboard_save_feedback_action"
                android:textColor="@color/md_theme_light_onPrimaryContainer"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/historyScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        android:orientation="vertical"
        android:paddingTop="48dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/historyPageHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/dashboard_history_title"
                    android:textColor="@color/md_theme_light_onSurface"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvHistoryPageSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/dashboard_history_subtitle"
                    android:textColor="@color/md_theme_light_onSurfaceVariant"
                    android:textSize="13sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvHistoryTotalDistance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/history_info_chip_background"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="7dp"
                        android:textColor="@color/md_theme_light_onPrimaryContainer"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        tools:text="累计 0.0 公里" />

                    <TextView
                        android:id="@+id/tvHistoryTotalDuration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/history_status_background"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="7dp"
                        android:textColor="@color/md_theme_light_onSecondaryContainer"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        tools:text="累计 0 分钟" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tvHistoryPageCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/history_status_background"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="@string/dashboard_history_count_zero"
                android:textColor="@color/md_theme_light_onSecondaryContainer"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="16dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvHistoryPage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:paddingStart="24dp"
                android:paddingTop="2dp"
                android:paddingEnd="24dp"
                android:paddingBottom="16dp" />

            <LinearLayout
                android:id="@+id/layoutHistoryEmptyPage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/history_item_background"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp"
                android:visibility="gone">

                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/history_icon_background">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_history"
                        android:tint="@color/md_theme_light_primary" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="@string/dashboard_history_empty_title"
                    android:textColor="@color/md_theme_light_onPrimaryContainer"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="@string/dashboard_history_empty_message"
                    android:textColor="@color/md_theme_light_onSurfaceVariant"
                    android:textSize="12sp" />
            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:id="@+id/historyPageBottomNav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="18dp">

            <View
                android:id="@+id/historyPageDivider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/md_theme_light_outlineVariant" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/historyPageTabRecord"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp">

                    <ImageView
                        android:id="@+id/ivHistoryPageTabRecord"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_tab_record"
                        android:tint="@color/dashboard_nav_inactive" />

                    <TextView
                        android:id="@+id/tvHistoryPageTabRecord"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/dashboard_record"
                        android:textColor="@color/dashboard_nav_inactive"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/historyPageTabHistory"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp">

                    <ImageView
                        android:id="@+id/ivHistoryPageTabHistory"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_tab_history"
                        android:tint="@color/md_theme_light_primary" />

                    <TextView
                        android:id="@+id/tvHistoryPageTabHistory"
                        android:layout_width="wrap_content"
