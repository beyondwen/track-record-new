<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="8dp"
    android:paddingTop="8dp"
    android:paddingEnd="8dp"
    android:paddingBottom="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <FrameLayout
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/history_icon_background">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/ic_history"
                app:tint="@color/md_theme_light_secondary" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="历史轨迹"
                android:textColor="?attr/colorOnSurface"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvHistoryPanelDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="最近完成的轨迹会显示在最上方"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvHistoryCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/history_status_background"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:text="0 条记录"
            android:textColor="@color/md_theme_light_onSecondaryContainer"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvHistory"
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingBottom="4dp" />

    <LinearLayout
        android:id="@+id/layoutHistoryEmpty"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/history_item_background"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="18dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="暂无轨迹记录"
            android:textColor="@color/md_theme_light_onPrimaryContainer"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="移动一段时间后离开页面，系统会自动生成轨迹。"
            android:textColor="@color/md_theme_light_onSurfaceVariant"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/btnHistoryEmptyAction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/location_metric_background"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:text="查看说明"
            android:textColor="@color/md_theme_light_onPrimaryContainer"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvHistoryHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="点击任意轨迹卡片即可查看详情。"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textSize="11sp" />

</LinearLayout>
